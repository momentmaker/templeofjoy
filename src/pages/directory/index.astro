---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import FilterBar from '../../components/FilterBar.astro';

const allDevotees = await getCollection('devotees');
const devotees = allDevotees.sort(
  (a, b) => b.data.dateAdded.getTime() - a.data.dateAdded.getTime()
);
---

<BaseLayout
  title="Community Directory | Temple of Joy"
  description="Browse devotees of Paramhansa Yogananda offering practice, creative, and service gifts."
>
  <section class="section">
    <div class="container">
      <header class="directory-header">
        <h1>Community Directory</h1>
        <p class="directory-subtitle">
          Devotees sharing their gifts across the world
        </p>
        <button type="button" class="btn-lucky" id="feeling-lucky">Discover a Devotee</button>
      </header>

      <SearchBar />
      <FilterBar />

      <div class="grid" id="directory-grid">
        {devotees.map((devotee) => (
          <ListingCard
            slug={devotee.id}
            displayName={devotee.data.displayName}
            country={devotee.data.country}
            city={devotee.data.city}
            stateRegion={devotee.data.stateRegion}
            categories={devotee.data.categories}
            tags={devotee.data.tags}
            description={devotee.data.description}
            photo={devotee.data.photo}
          />
        ))}
      </div>

      <div class="no-results" id="no-results" aria-hidden="true" hidden>
        <p>No devotees found matching your filters.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .directory-header {
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  .directory-subtitle {
    margin-top: var(--space-sm);
    color: var(--color-sage);
    font-size: 1.125rem;
  }

  .btn-lucky {
    margin-top: var(--space-lg);
    padding: var(--space-sm) var(--space-xl);
    background: transparent;
    color: var(--color-ochre);
    border: 1.5px solid var(--color-ochre);
    border-radius: var(--radius-lg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .btn-lucky:hover {
    background: var(--color-ochre);
    color: var(--color-cream);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
  }

  .no-results {
    text-align: center;
    padding: var(--space-3xl) 0;
    color: var(--color-sage);
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const grid = document.getElementById('directory-grid');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('directory-search') as HTMLInputElement | null;
  const countrySelect = document.getElementById('filter-country') as HTMLSelectElement | null;
  const tagSelect = document.getElementById('filter-tag') as HTMLSelectElement | null;
  const categoryButtons = document.querySelectorAll<HTMLButtonElement>('[data-category]');

  let activeCategory = 'all';

  function applyFilters() {
    if (!grid) return;

    const searchQuery = searchInput?.value.trim().toLowerCase() ?? '';
    const selectedCountry = countrySelect?.value ?? '';
    const selectedTag = tagSelect?.value ?? '';

    const cards = grid.querySelectorAll<HTMLElement>('.listing-card');
    let visibleCount = 0;

    cards.forEach((card) => {
      const cardCategories = card.dataset.categories?.split(',') ?? [];
      const cardTags = card.dataset.tags?.split(',') ?? [];
      const cardCountry = card.dataset.country ?? '';
      const cardSearchable = card.dataset.searchable ?? '';

      const matchesCategory =
        activeCategory === 'all' || cardCategories.includes(activeCategory.charAt(0).toUpperCase() + activeCategory.slice(1));

      const matchesCountry = selectedCountry === '' || cardCountry === selectedCountry;

      const matchesTag = selectedTag === '' || cardTags.includes(selectedTag);

      const matchesSearch = searchQuery === '' || cardSearchable.includes(searchQuery);

      const visible = matchesCategory && matchesCountry && matchesTag && matchesSearch;

      card.hidden = !visible;
      if (visible) visibleCount++;
    });

    if (noResults) {
      noResults.hidden = visibleCount > 0;
      noResults.setAttribute('aria-hidden', String(visibleCount > 0));
    }
  }

  categoryButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category ?? 'all';

      categoryButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);
  countrySelect?.addEventListener('change', applyFilters);
  tagSelect?.addEventListener('change', applyFilters);

  document.getElementById('feeling-lucky')?.addEventListener('click', () => {
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLAnchorElement>('.listing-card:not([hidden])'));
    if (cards.length === 0) return;
    const random = cards[Math.floor(Math.random() * cards.length)];
    window.location.href = random.href;
  });
</script>
