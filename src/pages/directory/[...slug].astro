---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatTag } from '../../data/tags';
import { getInitials, getAvatarColor } from '../../data/avatar';

export async function getStaticPaths() {
  const devotees = await getCollection('devotees');
  return devotees.map((devotee) => ({
    params: { slug: devotee.id },
    props: { devotee },
  }));
}

const { devotee } = Astro.props;
const { data } = devotee;
const { Content } = await render(devotee);

const location = [data.city, data.stateRegion, data.country].filter(Boolean).join(', ');

function contactLabel(method: string): string {
  if (method === 'email') return 'Send Email';
  if (method === 'website') return 'Visit Website';
  return 'Connect';
}

function contactHref(method: string, value: string): string {
  if (method === 'email') return `mailto:${value}`;
  return value;
}

const initials = getInitials(data.displayName);
const avatarColor = getAvatarColor(data.displayName);

const availableForLabels: Record<string, string> = {
  'in-person': 'In Person',
  virtual: 'Virtual',
  travel: 'Travel',
  collaboration: 'Collaboration',
};
---

<BaseLayout title={`${data.displayName} | Temple of Joy`} description={data.description} ogImage={`/og/${devotee.id}.png`}>
  <div class="profile">
    <div class="container">
      <a href="/directory/" class="back-link">← Back to Directory</a>

      <div class="profile-header">
        <div class="profile-photo-wrap">
          {data.photo ? (
            <img
              src={data.photo}
              alt={data.displayName}
              class="profile-photo"
              width="160"
              height="160"
            />
          ) : (
            <div class="profile-avatar" style={`background: ${avatarColor.bg}; color: ${avatarColor.text};`}>
              {initials}
            </div>
          )}
        </div>
        <div class="profile-meta">
          <h1 class="profile-name">{data.displayName}</h1>
          <p class="profile-location">{location}</p>
          {data.communityLineage && (
            <p class="profile-lineage">{data.communityLineage}</p>
          )}

          <div class="profile-tags">
            {data.categories.map((cat) => (
              <span class="tag tag-category">{cat}</span>
            ))}
            {data.tags.map((tag) => (
              <span class="tag">{formatTag(tag)}</span>
            ))}
          </div>

          {data.availableFor.length > 0 && (
            <div class="available-for">
              <span class="available-label">Available for:</span>
              {data.availableFor.map((item) => (
                <span class="tag">{availableForLabels[item] ?? item}</span>
              ))}
            </div>
          )}

          {data.openToMentorship && (
            <p class="mentorship-badge">Open to Mentorship</p>
          )}
        </div>
      </div>

      {data.guidingQuote && (
        <blockquote class="guiding-quote">
          <p>{data.guidingQuote}</p>
        </blockquote>
      )}

      <div class="profile-body">
        <section class="about-section">
          <h2>About</h2>
          <p>{data.description}</p>
        </section>

        <section class="path-section">
          <h2>My Path</h2>
          <div class="prose">
            <Content />
          </div>
        </section>
      </div>
    </div>

    {data.joyInAction && (
      <div class="joy-section section-alt">
        <div class="container">
          <h2>Joy in Action</h2>
          <p class="joy-story">{data.joyInAction}</p>
        </div>
      </div>
    )}

    <div class="container">
      <div class="contact-section">
        <h2>Connect</h2>
        <div class="contact-buttons">
          <a
            href={contactHref(data.contactMethod, data.contactValue)}
            class="btn btn-primary"
            target={data.contactMethod !== 'email' ? '_blank' : undefined}
            rel={data.contactMethod !== 'email' ? 'noopener noreferrer' : undefined}
          >
            {contactLabel(data.contactMethod)}
          </a>
          {data.websiteUrl && (
            <a
              href={data.websiteUrl}
              class="btn btn-outline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Website
            </a>
          )}
          {data.additionalLinks.map((link) => (
            <a
              href={link.url}
              class="btn btn-outline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .profile {
    padding-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    margin: var(--space-xl) 0 var(--space-lg);
    font-size: 0.9rem;
    color: var(--color-sage);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-ochre);
  }

  .profile-header {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
    margin-bottom: var(--space-2xl);
  }

  .profile-photo-wrap {
    flex-shrink: 0;
  }

  .profile-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-gold);
  }

  .profile-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 600;
    letter-spacing: 2px;
  }

  .profile-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .profile-name {
    font-size: 2rem;
    margin: 0;
  }

  .profile-location {
    color: var(--color-sage);
    margin: 0;
  }

  .profile-lineage {
    color: var(--color-ochre);
    font-style: italic;
    font-size: 0.95rem;
    margin: 0;
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .tag-category {
    background: var(--color-navy);
    color: var(--color-cream);
    font-weight: 600;
  }

  .available-for {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .available-label {
    font-size: 0.85rem;
    color: var(--color-sage);
    font-weight: 500;
  }

  .mentorship-badge {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-sage);
    border: 1px solid var(--color-sage);
    border-radius: var(--radius-sm);
    padding: 2px var(--space-sm);
    width: fit-content;
    margin: 0;
  }

  .guiding-quote {
    border-left: 4px solid var(--color-ochre);
    padding: var(--space-md) var(--space-lg);
    margin: 0 0 var(--space-2xl);
    background: var(--color-stone);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .guiding-quote p {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-navy);
    margin: 0;
  }

  .profile-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  .about-section h2,
  .path-section h2 {
    margin-bottom: var(--space-md);
  }

  .prose {
    line-height: 1.7;
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
  }

  .joy-section {
    padding: var(--space-2xl) 0;
    margin-bottom: var(--space-2xl);
  }

  .joy-section h2 {
    margin-bottom: var(--space-md);
  }

  .joy-story {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 720px;
  }

  .contact-section h2 {
    margin-bottom: var(--space-lg);
  }

  .contact-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .profile-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-tags,
    .available-for,
    .contact-buttons {
      justify-content: center;
    }

    .mentorship-badge {
      margin: 0 auto;
    }

    .guiding-quote {
      margin-left: 0;
    }
  }
</style>
