---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';

const allDevotees = await getCollection('devotees');

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const quoteDevotees = shuffle(allDevotees.filter((d) => d.data.guidingQuote));
const storyDevotees = shuffle(allDevotees.filter((d) => d.data.joyInAction));

const recentListings = [...allDevotees]
  .sort((a, b) => b.data.dateAdded.getTime() - a.data.dateAdded.getTime())
  .slice(0, 6);
---

<BaseLayout
  title="Temple of Joy — A Community of Yogananda's Devotees"
  description="A community of Yogananda's devotees offering their gifts to the world through practice, creativity, and service."
>
  <section class="hero">
    <div class="container hero-inner">
      <h1 class="hero-title">Temple of Joy</h1>
      <p class="hero-tagline">Joy expressed through service</p>
      <p class="hero-description">
        A community of Yogananda's devotees offering their gifts to the world
        — through practice, creativity, and service. Find them here, or share your own.
      </p>
      <div class="hero-actions">
        <a href="/community/" class="btn btn-primary">Meet the Community</a>
        <a href="/submit/" class="btn btn-outline">Share Your Gifts</a>
      </div>
    </div>
  </section>

  {quoteDevotees.length > 0 && (
    <section class="quote-section section">
      <div
        class="container carousel"
        data-carousel="quote"
        data-count={quoteDevotees.length}
        role="region"
        aria-roledescription="carousel"
        aria-label="Guiding quotes from devotees"
      >
        <div class="carousel-slides quote-slides">
          {quoteDevotees.map((d, i) => (
            <blockquote
              class="featured-quote carousel-slide"
              data-index={i}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <p class="quote-text">&ldquo;{d.data.guidingQuote}&rdquo;</p>
              <footer class="quote-attribution">
                &mdash;{' '}
                <a href={`/community/${d.id}/`} class="quote-link">
                  {d.data.displayName}
                </a>
              </footer>
            </blockquote>
          ))}
        </div>
        {quoteDevotees.length > 1 && (
          <div class="carousel-dots" role="tablist" aria-label="Choose a quote">
            {quoteDevotees.map((d, i) => (
              <button
                type="button"
                class="carousel-dot"
                data-index={i}
                role="tab"
                aria-label={`Show quote from ${d.data.displayName}`}
                aria-selected={i === 0 ? 'true' : 'false'}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {recentListings.length > 0 && (
    <section class="listings-section section">
      <div class="container">
        <header class="section-header">
          <h2>From the Community</h2>
          <p class="section-subtitle">Devotees sharing their gifts across the world</p>
        </header>
        <div class="listings-grid">
          {recentListings.map((devotee) => (
            <ListingCard
              slug={devotee.id}
              displayName={devotee.data.displayName}
              country={devotee.data.country}
              city={devotee.data.city}
              stateRegion={devotee.data.stateRegion}
              categories={devotee.data.categories}
              tags={devotee.data.tags}
              description={devotee.data.description}
              photo={devotee.data.photo}
            />
          ))}
        </div>
        <div class="section-footer">
          <a href="/community/" class="btn btn-outline">See Everyone</a>
        </div>
      </div>
    </section>
  )}

  {storyDevotees.length > 0 && (
    <section class="story-section section">
      <div class="container">
        <header class="section-header">
          <h2>Joy in Action</h2>
        </header>
        <div
          class="carousel"
          data-carousel="story"
          data-count={storyDevotees.length}
          role="region"
          aria-roledescription="carousel"
          aria-label="Joy in Action stories from devotees"
        >
          <div class="carousel-slides story-slides">
            {storyDevotees.map((d, i) => (
              <div
                class="story-box carousel-slide"
                data-index={i}
                aria-hidden={i === 0 ? 'false' : 'true'}
              >
                <p class="story-text">{d.data.joyInAction}</p>
                <p class="story-attribution">
                  &mdash;{' '}
                  <a href={`/community/${d.id}/`} class="story-link">
                    {d.data.displayName}
                  </a>
                </p>
              </div>
            ))}
          </div>
          {storyDevotees.length > 1 && (
            <div class="carousel-dots" role="tablist" aria-label="Choose a story">
              {storyDevotees.map((d, i) => (
                <button
                  type="button"
                  class="carousel-dot"
                  data-index={i}
                  role="tab"
                  aria-label={`Show story from ${d.data.displayName}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="cta-section section">
    <div class="container cta-inner">
      <h2>Share Your Gifts</h2>
      <p class="cta-description">
        Are you a devotee offering something to the community? Add your listing
        and let others find you.
      </p>
      <a href="/submit/" class="btn btn-primary">Submit Your Listing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-stone) 100%);
    padding: var(--space-3xl) 0;
  }

  .hero-inner {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.375rem;
    color: var(--color-ochre);
    margin-bottom: var(--space-lg);
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-navy);
    margin-bottom: var(--space-2xl);
    opacity: 0.85;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .quote-section {
    text-align: center;
  }

  .featured-quote {
    margin: 0 auto;
    max-width: 620px;
    border: none;
    padding: 0;
  }

  .quote-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.375rem;
    line-height: 1.65;
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .quote-attribution {
    font-size: 0.9375rem;
    color: var(--color-sage);
  }

  .quote-link {
    color: var(--color-ochre);
    text-decoration: none;
  }

  .quote-link:hover {
    text-decoration: underline;
  }

  .listings-section {
    background: var(--color-stone);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .section-subtitle {
    margin-top: var(--space-sm);
    color: var(--color-sage);
    font-size: 1.0625rem;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
  }

  .section-footer {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .story-section {
    background: var(--color-cream);
  }

  .story-box {
    background: var(--color-stone);
    border-left: 4px solid var(--color-ochre);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    max-width: 680px;
    margin-inline: auto;
  }

  .story-text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .story-attribution {
    font-size: 0.9375rem;
    color: var(--color-sage);
    margin: 0;
  }

  .story-link {
    color: var(--color-ochre);
    text-decoration: none;
  }

  .story-link:hover {
    text-decoration: underline;
  }

  .cta-section {
    background: var(--color-stone);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-navy);
    margin-bottom: var(--space-xl);
    opacity: 0.85;
  }

  .carousel {
    position: relative;
  }

  .carousel-slides {
    position: relative;
  }

  .quote-slides {
    max-width: 620px;
    margin-inline: auto;
    min-height: 11rem;
  }

  .story-slides {
    max-width: 680px;
    margin-inline: auto;
    min-height: 16rem;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms ease-in-out;
    pointer-events: none;
  }

  .carousel-slide[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .carousel-slide.featured-quote {
    margin: 0;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .carousel-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: var(--color-sage);
    opacity: 0.35;
    cursor: pointer;
    transition: opacity 200ms ease, background 200ms ease, transform 200ms ease;
  }

  .carousel-dot:hover,
  .carousel-dot:focus-visible {
    opacity: 0.7;
    outline: none;
  }

  .carousel-dot[aria-selected='true'] {
    background: var(--color-ochre);
    opacity: 1;
    transform: scale(1.15);
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-slide {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .listings-grid {
      grid-template-columns: 1fr;
    }

    .story-box {
      padding: var(--space-lg);
    }

    .quote-slides {
      min-height: 13rem;
    }

    .story-slides {
      min-height: 20rem;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const ROTATION_MS = 7000;

  function initCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.carousel-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.carousel-dot'));
    if (slides.length <= 1) return;

    let current = 0;
    let timer: number | null = null;

    function show(idx: number) {
      slides.forEach((slide, i) => {
        slide.setAttribute('aria-hidden', i === idx ? 'false' : 'true');
      });
      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
      current = idx;
    }

    function next() {
      show((current + 1) % slides.length);
    }

    function start() {
      if (reduceMotion || timer !== null) return;
      timer = window.setInterval(next, ROTATION_MS);
    }

    function stop() {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        stop();
        show(i);
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);

    start();
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
